{
  "name": "@afrows/client",
  "version": "0.114.41",
  "private": true,
  "scripts": {
    "predev": "npm --workspace @afrows/shared run build",
    "dev": "vite --host 127.0.0.1 --port 4100 --strictPort",
    "prebuild": "npm --workspace @afrows/shared run build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4100 --strictPort",
