    "typecheck": "tsc --noEmit",
    "lint": "echo \"client lint not configured yet\""
  },
  "dependencies": {
    "@afrows/shared": "0.114.41",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
