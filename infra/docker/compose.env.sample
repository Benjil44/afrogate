# Copy to compose.env and replace every empty value before running Docker Compose.
# Keep compose.env untracked.

AFROWS_POSTGRES_PASSWORD=

# For first boot, plaintext is accepted. Prefer a password hash for production.
AFROWS_SUPERADMIN_USERNAME=superadmin
AFROWS_SUPERADMIN_PASSWORD=
AFROWS_SUPERADMIN_PASSWORD_HASH=

ADMIN_SESSION_SECRET=
AFROWS_SECRETS_KEY=
AFROWS_SECRETS_KEY_ID=docker-v1

CORS_ORIGIN=http://127.0.0.1:8080,http://localhost:8080
