# Optional monitoring agent environment for /etc/afrows/agent.env.
# Install this only on nodes that should push metrics to Afrows.

AFROWS_AGENT_ID=server-01
AFROWS_API_URL=https://afrows.example.com/api
AFROWS_AGENT_TOKEN=replace-with-registered-agent-token
AFROWS_PUSH_INTERVAL_SECONDS=10
AFROWS_AGENT_STATE_FILE=/var/lib/afrows-agent/state.json

# Optional control-plane egress proxy for agent API pushes from restricted nodes.
AFROWS_OUTBOUND_PROXY_URL=

# Optional synthetic ping probes. Use targets you control or accept.
AFROWS_PING_TARGETS=
AFROWS_PING_COUNT=3
AFROWS_PING_TIMEOUT_SECONDS=2

# Optional protocol-aware probes. UDP/QUIC targets must reply to the small probe payload.
# WireGuard route-probe rows are derived from local `wg` telemetry when available.
AFROWS_TCP_PROBE_TARGETS=
AFROWS_UDP_PROBE_TARGETS=
AFROWS_QUIC_PROBE_TARGETS=
AFROWS_DNS_PROBE_TARGETS=
AFROWS_ROUTE_PROBE_COUNT=2
AFROWS_ROUTE_PROBE_TIMEOUT_SECONDS=2

# Optional non-secret dimensions for operator/outbound time-window analytics.
AFROWS_ROUTE_PROBE_ROUTE_GROUP=main
AFROWS_ROUTE_PROBE_OUTBOUND_ID=
AFROWS_ROUTE_PROBE_OUTBOUND_KEY=
AFROWS_ROUTE_PROBE_OUTBOUND_NAME=
AFROWS_ROUTE_PROBE_OPERATOR=
AFROWS_ROUTE_PROBE_SCORE_PROFILE=
