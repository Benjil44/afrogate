# Optional monitoring agent environment for /etc/afrogate/agent.env.
# Install this only on nodes that should push metrics to AfroGate.

AFROGATE_AGENT_ID=server-01
AFROGATE_API_URL=https://afrogate.example.com/api
AFROGATE_AGENT_TOKEN=replace-with-registered-agent-token
AFROGATE_PUSH_INTERVAL_SECONDS=10
AFROGATE_AGENT_STATE_FILE=/var/lib/afrogate-agent/state.json

# Optional control-plane egress proxy for agent API pushes from restricted nodes.
AFROGATE_OUTBOUND_PROXY_URL=

# Optional synthetic ping probes. Use targets you control or accept.
AFROGATE_PING_TARGETS=
AFROGATE_PING_COUNT=3
AFROGATE_PING_TIMEOUT_SECONDS=2

# Optional protocol-aware probes. UDP/QUIC targets must reply to the small probe payload.
# WireGuard route-probe rows are derived from local `wg` telemetry when available.
AFROGATE_TCP_PROBE_TARGETS=
AFROGATE_UDP_PROBE_TARGETS=
AFROGATE_QUIC_PROBE_TARGETS=
AFROGATE_DNS_PROBE_TARGETS=
AFROGATE_ROUTE_PROBE_COUNT=2
AFROGATE_ROUTE_PROBE_TIMEOUT_SECONDS=2

# Optional non-secret dimensions for operator/outbound time-window analytics.
AFROGATE_ROUTE_PROBE_ROUTE_GROUP=main
AFROGATE_ROUTE_PROBE_OUTBOUND_ID=
AFROGATE_ROUTE_PROBE_OUTBOUND_KEY=
AFROGATE_ROUTE_PROBE_OUTBOUND_NAME=
AFROGATE_ROUTE_PROBE_OPERATOR=
AFROGATE_ROUTE_PROBE_SCORE_PROFILE=
