# Backend runtime environment for /etc/afrogate/afrogate.env.
# Replace every placeholder before starting the service.

PORT=7000
HOST=127.0.0.1
CORS_ORIGIN=https://afrogate.example.com
DATABASE_URL=postgresql://afrogate_app:replace-with-db-password@127.0.0.1:5432/afrogate
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Prefer a hash in production. Leave plaintext password empty when a hash is configured.
AFROGATE_SUPERADMIN_USERNAME=superadmin
AFROGATE_SUPERADMIN_PASSWORD=
AFROGATE_SUPERADMIN_PASSWORD_HASH=replace-with-scrypt-password-hash
ADMIN_SESSION_SECRET=replace-with-long-random-session-secret
ADMIN_SESSION_TTL_SECONDS=28800
AFROGATE_ADMIN_USERS_FILE=/var/lib/afrogate/admin-users.json

# Legacy fallbacks. Prefer login sessions and database-issued agent tokens. Rotate database agent
# tokens with POST /api/agents/:serverId/tokens/rotate, then update the agent service env.
AFROGATE_ADMIN_TOKEN=
AFROGATE_AGENT_TOKEN=

# Required before storing Settings/server secrets. Must decode to exactly 32 bytes.
AFROGATE_SECRETS_KEY=replace-with-32-byte-base64-or-64-char-hex
AFROGATE_SECRETS_KEY_ID=production-v1
# Optional separate HMAC key for paid-number hashes. Falls back to AFROGATE_SECRETS_KEY.
AFROGATE_IDENTITY_HASH_KEY=replace-with-long-random-identity-hash-key

# Optional control-plane egress proxy for Telegram/API calls from restricted servers.
AFROGATE_OUTBOUND_PROXY_URL=

# Superadmin Settings can store Telegram secrets encrypted/write-only; env values stay as bootstrap/fallback.
AFROGATE_TELEGRAM_ALERTS_ENABLED=false
AFROGATE_TELEGRAM_BOT_TOKEN=
AFROGATE_TELEGRAM_ALERT_CHAT_ID=
AFROGATE_TELEGRAM_API_BASE_URL=https://api.telegram.org
AFROGATE_TELEGRAM_TIMEOUT_MS=10000
AFROGATE_ALERT_DELIVERY_INTERVAL_SECONDS=10
AFROGATE_ALERT_DELIVERY_BATCH_SIZE=20
AFROGATE_TELEGRAM_ALERT_COOLDOWN_SECONDS=300

AFROGATE_OUTBOUND_HEALTH_SCHEDULER_ENABLED=true
AFROGATE_OUTBOUND_HEALTH_SCAN_INTERVAL_SECONDS=10
AFROGATE_OUTBOUND_HEALTH_BATCH_SIZE=20
AFROGATE_OUTBOUND_HEALTH_TIMEOUT_MS=5000

AFROGATE_ROUTE_QUALITY_AGGREGATION_ENABLED=true
AFROGATE_ROUTE_QUALITY_AGGREGATION_INTERVAL_SECONDS=300
AFROGATE_ROUTE_QUALITY_AGGREGATION_LOOKBACK_HOURS=48
AFROGATE_ROUTE_QUALITY_PREDICTION_LOOKAHEAD_HOURS=8

# Keep disabled until the production apply engines are implemented and audited.
AFROGATE_ROUTE_DATA_PLANE_APPLY_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_LIVE_EXECUTOR_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_SECRET_DECRYPT_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_CREDENTIAL_DECRYPT_ENABLED=false

AFROGATE_ALERT_ENGINE_ENABLED=true
AFROGATE_ALERT_ENGINE_INTERVAL_SECONDS=10
AFROGATE_ALERT_ENGINE_BATCH_SIZE=100
AFROGATE_ALERT_STALE_SERVER_SECONDS=90
AFROGATE_ALERT_STALE_METRICS_SECONDS=120
AFROGATE_ALERT_CPU_WARNING_PERCENT=85
AFROGATE_ALERT_CPU_CRITICAL_PERCENT=95
AFROGATE_ALERT_RAM_WARNING_PERCENT=85
AFROGATE_ALERT_RAM_CRITICAL_PERCENT=95
AFROGATE_ALERT_DISK_WARNING_FREE_PERCENT=15
AFROGATE_ALERT_DISK_CRITICAL_FREE_PERCENT=10
AFROGATE_ALERT_PING_WARNING_MS=100
AFROGATE_ALERT_PING_CRITICAL_MS=150
AFROGATE_ALERT_JITTER_WARNING_MS=40
AFROGATE_ALERT_JITTER_CRITICAL_MS=80
AFROGATE_ALERT_PACKET_LOSS_WARNING_PERCENT=1
AFROGATE_ALERT_PACKET_LOSS_CRITICAL_PERCENT=5
