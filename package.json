{
  "name": "afrogate",
  "version": "0.108.1",
  "private": true,
  "description": "AfroGate operations, monitoring, routing, and billing platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:backend": "npm --workspace @afrogate/backend run dev",
    "dev:dashboard": "npm --workspace @afrogate/dashboard run dev",
    "dev:client": "npm --workspace @afrogate/client run dev",
    "agent:dev": "python apps/agent/run.py --once",
    "db:setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-postgres.ps1",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "contrast:check": "node scripts/check-dashboard-contrast.mjs",
    "secrets:check": "node scripts/check-secrets.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "version:set": "node scripts/bump-version.mjs",
    "version:check": "node plugins/afrogate-versioning/scripts/check-version.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
