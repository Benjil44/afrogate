# Backend
PORT=7000
HOST=127.0.0.1
CORS_ORIGIN=http://127.0.0.1:4000,http://localhost:4000
# Runtime backend connection. Use the least-privilege app role.
DATABASE_URL=postgresql://afrows_app:replace-with-runtime-db-password@localhost:5432/afrows
# Optional migration-only connection. Prefer setting this only in the migration shell,
# not in the long-running backend service environment.
DATABASE_MIGRATION_URL=postgresql://afrows_migrator:replace-with-migration-db-password@localhost:5432/afrows
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Legacy fallback before database-issued agent tokens are registered. Change this in every environment
# or leave unset after agents receive tokens from POST /api/agents/register. Rotate database tokens
# through POST /api/agents/:serverId/tokens/rotate and update the agent environment immediately.
AFROWS_AGENT_TOKEN=change-me-local-token
# Dashboard login. Use password hash in production when possible:
# AFROWS_SUPERADMIN_PASSWORD_HASH=scrypt$16384$8$1$base64url-salt$base64url-hash
AFROWS_SUPERADMIN_USERNAME=superadmin
AFROWS_SUPERADMIN_PASSWORD=change-me-superadmin-password
AFROWS_ADMIN_USERNAME=
AFROWS_ADMIN_PASSWORD=
AFROWS_ADMIN_PASSWORD_HASH=
AFROWS_ADMIN_ROLE=admin
ADMIN_SESSION_SECRET=change-me-long-random-secret
ADMIN_SESSION_TTL_SECONDS=28800
# Managed admin users default to PostgreSQL when DATABASE_URL is configured.
# Set to file only for legacy local development; production should keep database.
AFROWS_ADMIN_USERS_STORE=database
# Optional one-time legacy import source when the database admin_users table is empty.
AFROWS_ADMIN_USERS_FILE=tmp/admin-users.json
AFROWS_ADMIN_USERS_IMPORT_FILE=true
# Legacy fallback for direct bearer-token admin API calls. Prefer username/password login.
AFROWS_ADMIN_TOKEN=change-me-admin-token
# In-memory API rate limiting for sensitive public endpoints. Trust proxy headers only behind Nginx.
AFROWS_RATE_LIMIT_ENABLED=true
# PRODUCTION: set to true when running behind the Nginx reverse proxy so per-IP rate
# limits use the real client IP (X-Forwarded-For / X-Real-IP) instead of the proxy's.
# Keep false for direct/local exposure to avoid clients spoofing their IP.
AFROWS_RATE_LIMIT_TRUST_PROXY_HEADERS=false
AFROWS_RATE_LIMIT_MAX_KEYS=5000
# 32-byte base64/base64url or 64-char hex key for encrypted Settings/server secrets.
# Generate per environment and back it up securely; losing it makes stored secrets unreadable.
AFROWS_SECRETS_KEY=
AFROWS_SECRETS_KEY_ID=local-v1
# Optional HMAC key for write-only paid-number hashes. If unset, AFROWS_SECRETS_KEY is used.
AFROWS_IDENTITY_HASH_KEY=
# Optional app-level outbound proxy for Telegram/API calls from restricted servers.
# For VLESS, run a local client such as sing-box/xray that exposes an HTTP proxy on localhost.
AFROWS_OUTBOUND_PROXY_URL=
# Optional Telegram critical-alert delivery. Superadmin Settings can store these encrypted/write-only;
# env values remain a bootstrap/fallback path for deployments that prefer environment secrets.
AFROWS_TELEGRAM_ALERTS_ENABLED=false
AFROWS_TELEGRAM_BOT_TOKEN=
AFROWS_TELEGRAM_ALERT_CHAT_ID=
AFROWS_TELEGRAM_API_BASE_URL=https://api.telegram.org
AFROWS_TELEGRAM_TIMEOUT_MS=10000
# Optional Telegram user-command webhook. Requires Telegram's secret-token header.
AFROWS_TELEGRAM_BOT_COMMANDS_ENABLED=false
AFROWS_TELEGRAM_WEBHOOK_SECRET=
AFROWS_ALERT_DELIVERY_INTERVAL_SECONDS=10
AFROWS_ALERT_DELIVERY_BATCH_SIZE=20
AFROWS_TELEGRAM_ALERT_COOLDOWN_SECONDS=300
# Optional PayPal checkout/capture provider adapter. Keep disabled until sandbox/live credentials
# and a PayPal webhook ID are configured. Secrets must stay in env or secret storage, not public config.
AFROWS_PAYPAL_ENABLED=false
AFROWS_PAYPAL_ENVIRONMENT=sandbox
AFROWS_PAYPAL_API_BASE_URL=
AFROWS_PAYPAL_CLIENT_ID=
AFROWS_PAYPAL_CLIENT_SECRET=
AFROWS_PAYPAL_WEBHOOK_ID=
AFROWS_PAYPAL_RETURN_URL=
AFROWS_PAYPAL_CANCEL_URL=
AFROWS_PAYPAL_TIMEOUT_MS=12000
# Optional signed rewarded-ad provider webhook. Set dashboard verification mode to signed_webhook.
AFROWS_REWARDED_AD_WEBHOOK_SECRET=
AFROWS_REWARDED_AD_WEBHOOK_TOLERANCE_SECONDS=300
# Outbound route/gateway health scheduler. Checks due enabled outbounds with healthUrl or host/port.
AFROWS_OUTBOUND_HEALTH_SCHEDULER_ENABLED=true
AFROWS_OUTBOUND_HEALTH_SCAN_INTERVAL_SECONDS=10
AFROWS_OUTBOUND_HEALTH_BATCH_SIZE=20
AFROWS_OUTBOUND_HEALTH_TIMEOUT_MS=5000
# Route-quality analytics aggregation. Compacts historical synthetic route probes into hourly summaries.
AFROWS_ROUTE_QUALITY_AGGREGATION_ENABLED=true
AFROWS_ROUTE_QUALITY_AGGREGATION_INTERVAL_SECONDS=300
AFROWS_ROUTE_QUALITY_AGGREGATION_LOOKBACK_HOURS=48
AFROWS_ROUTE_QUALITY_PREDICTION_LOOKAHEAD_HOURS=8
# Data-plane route/protocol apply remains disabled until server-side adapters are audited.
AFROWS_ROUTE_DATA_PLANE_APPLY_ENABLED=false
AFROWS_PROTOCOL_SERVER_APPLY_ENABLED=false
AFROWS_PROTOCOL_SERVER_APPLY_LIVE_EXECUTOR_ENABLED=false
AFROWS_PROTOCOL_SERVER_APPLY_SECRET_DECRYPT_ENABLED=false
AFROWS_PROTOCOL_SERVER_APPLY_CREDENTIAL_DECRYPT_ENABLED=false
# Read-only backup status monitoring. External backup jobs may write the JSON status file.
AFROWS_BACKUP_MONITORING_ENABLED=false
AFROWS_BACKUP_STATUS_FILE=
AFROWS_BACKUP_MAX_AGE_HOURS=30
AFROWS_BACKUP_RESTORE_TEST_MAX_AGE_DAYS=30
AFROWS_BACKUP_ENCRYPTION_REQUIRED=true
AFROWS_BACKUP_RETENTION_DAILY_DAYS=7
AFROWS_BACKUP_RETENTION_WEEKLY_WEEKS=4
AFROWS_BACKUP_RETENTION_MONTHLY_MONTHS=3
AFROWS_BACKUP_DESTINATION_TYPE=
AFROWS_BACKUP_DESTINATION_LABEL=
AFROWS_BACKUP_ARTIFACTS=postgres,config,secrets
# Alert engine thresholds. The engine creates/resolves alerts from latest metrics and outbound health.
AFROWS_ALERT_ENGINE_ENABLED=true
AFROWS_ALERT_ENGINE_INTERVAL_SECONDS=10
AFROWS_ALERT_ENGINE_BATCH_SIZE=100
AFROWS_ALERT_STALE_SERVER_SECONDS=90
AFROWS_ALERT_STALE_METRICS_SECONDS=120
AFROWS_ALERT_CPU_WARNING_PERCENT=85
AFROWS_ALERT_CPU_CRITICAL_PERCENT=95
AFROWS_ALERT_RAM_WARNING_PERCENT=85
AFROWS_ALERT_RAM_CRITICAL_PERCENT=95
AFROWS_ALERT_DISK_WARNING_FREE_PERCENT=15
AFROWS_ALERT_DISK_CRITICAL_FREE_PERCENT=10
AFROWS_ALERT_PING_WARNING_MS=100
AFROWS_ALERT_PING_CRITICAL_MS=150
AFROWS_ALERT_JITTER_WARNING_MS=40
AFROWS_ALERT_JITTER_CRITICAL_MS=80
AFROWS_ALERT_PACKET_LOSS_WARNING_PERCENT=1
AFROWS_ALERT_PACKET_LOSS_CRITICAL_PERCENT=5

# Dashboard
VITE_API_BASE_URL=http://127.0.0.1:7000/api

# Agent
AFROWS_AGENT_ID=local-dev-agent
AFROWS_API_URL=http://127.0.0.1:7000/api
AFROWS_PUSH_INTERVAL_SECONDS=10
AFROWS_AGENT_STATE_FILE=
# Optional synthetic ping probes. Leave empty unless you control/accept the targets.
AFROWS_PING_TARGETS=
AFROWS_PING_COUNT=3
AFROWS_PING_TIMEOUT_SECONDS=2
# Optional protocol-aware route probes. Use synthetic targets you control.
# TCP targets are host:port. UDP/QUIC targets must reply to the small probe payload.
# DNS targets are hostnames to resolve through the local route.
# WireGuard route-probe rows are derived from local `wg` telemetry when available.
AFROWS_TCP_PROBE_TARGETS=
AFROWS_UDP_PROBE_TARGETS=
AFROWS_QUIC_PROBE_TARGETS=
AFROWS_DNS_PROBE_TARGETS=
# Optional DF/path-MTU diagnostics. Targets are synthetic hosts; no user destinations.
AFROWS_MTU_PROBE_TARGETS=
AFROWS_ROUTE_PROBE_COUNT=2
AFROWS_ROUTE_PROBE_TIMEOUT_SECONDS=2
AFROWS_ROUTE_PROBE_MTU_MIN_BYTES=1280
AFROWS_ROUTE_PROBE_MTU_MAX_BYTES=1500
AFROWS_ROUTE_PROBE_TUNNEL_OVERHEAD_BYTES=80
AFROWS_ROUTE_PROBE_CONFIGURED_MTU_BYTES=
# Optional route-probe dimensions for operator/outbound/time-window analytics.
AFROWS_ROUTE_PROBE_ROUTE_GROUP=main
AFROWS_ROUTE_PROBE_OUTBOUND_ID=
AFROWS_ROUTE_PROBE_OUTBOUND_KEY=
AFROWS_ROUTE_PROBE_OUTBOUND_NAME=
AFROWS_ROUTE_PROBE_OPERATOR=
AFROWS_ROUTE_PROBE_SCORE_PROFILE=
