# Backend
PORT=7000
HOST=127.0.0.1
CORS_ORIGIN=http://127.0.0.1:4000,http://localhost:4000
DATABASE_URL=postgresql://afrogate:afrogate@localhost:5432/afrogate
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Legacy fallback before database-issued agent tokens are registered. Change this in every environment
# or leave unset after agents receive tokens from POST /api/agents/register.
AFROGATE_AGENT_TOKEN=change-me-local-token
# Dashboard login. Use password hash in production when possible:
# AFROGATE_SUPERADMIN_PASSWORD_HASH=scrypt$16384$8$1$base64url-salt$base64url-hash
AFROGATE_SUPERADMIN_USERNAME=superadmin
AFROGATE_SUPERADMIN_PASSWORD=change-me-superadmin-password
AFROGATE_ADMIN_USERNAME=
AFROGATE_ADMIN_PASSWORD=
AFROGATE_ADMIN_PASSWORD_HASH=
AFROGATE_ADMIN_ROLE=admin
ADMIN_SESSION_SECRET=change-me-long-random-secret
ADMIN_SESSION_TTL_SECONDS=28800
AFROGATE_ADMIN_USERS_FILE=tmp/admin-users.json
# Legacy fallback for direct bearer-token admin API calls. Prefer username/password login.
AFROGATE_ADMIN_TOKEN=change-me-admin-token
# 32-byte base64/base64url or 64-char hex key for encrypted Settings/server secrets.
# Generate per environment and back it up securely; losing it makes stored secrets unreadable.
AFROGATE_SECRETS_KEY=
AFROGATE_SECRETS_KEY_ID=local-v1
# Optional app-level outbound proxy for Telegram/API calls from restricted servers.
# For VLESS, run a local client such as sing-box/xray that exposes an HTTP proxy on localhost.
AFROGATE_OUTBOUND_PROXY_URL=
# Optional Telegram critical-alert delivery. Keep disabled until real bot/chat values are configured.
AFROGATE_TELEGRAM_ALERTS_ENABLED=false
AFROGATE_TELEGRAM_BOT_TOKEN=
AFROGATE_TELEGRAM_ALERT_CHAT_ID=
AFROGATE_TELEGRAM_API_BASE_URL=https://api.telegram.org
AFROGATE_TELEGRAM_TIMEOUT_MS=10000
AFROGATE_ALERT_DELIVERY_INTERVAL_SECONDS=10
AFROGATE_ALERT_DELIVERY_BATCH_SIZE=20
AFROGATE_TELEGRAM_ALERT_COOLDOWN_SECONDS=300
# Outbound route/gateway health scheduler. Checks due enabled outbounds with healthUrl or host/port.
AFROGATE_OUTBOUND_HEALTH_SCHEDULER_ENABLED=true
AFROGATE_OUTBOUND_HEALTH_SCAN_INTERVAL_SECONDS=10
AFROGATE_OUTBOUND_HEALTH_BATCH_SIZE=20
AFROGATE_OUTBOUND_HEALTH_TIMEOUT_MS=5000
# Route-quality analytics aggregation. Compacts historical synthetic route probes into hourly summaries.
AFROGATE_ROUTE_QUALITY_AGGREGATION_ENABLED=true
AFROGATE_ROUTE_QUALITY_AGGREGATION_INTERVAL_SECONDS=300
AFROGATE_ROUTE_QUALITY_AGGREGATION_LOOKBACK_HOURS=48
AFROGATE_ROUTE_QUALITY_PREDICTION_LOOKAHEAD_HOURS=8
# Data-plane route/protocol apply remains disabled until server-side adapters are audited.
AFROGATE_ROUTE_DATA_PLANE_APPLY_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_LIVE_EXECUTOR_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_SECRET_DECRYPT_ENABLED=false
AFROGATE_PROTOCOL_SERVER_APPLY_CREDENTIAL_DECRYPT_ENABLED=false
# Alert engine thresholds. The engine creates/resolves alerts from latest metrics and outbound health.
AFROGATE_ALERT_ENGINE_ENABLED=true
AFROGATE_ALERT_ENGINE_INTERVAL_SECONDS=10
AFROGATE_ALERT_ENGINE_BATCH_SIZE=100
AFROGATE_ALERT_STALE_SERVER_SECONDS=90
AFROGATE_ALERT_STALE_METRICS_SECONDS=120
AFROGATE_ALERT_CPU_WARNING_PERCENT=85
AFROGATE_ALERT_CPU_CRITICAL_PERCENT=95
AFROGATE_ALERT_RAM_WARNING_PERCENT=85
AFROGATE_ALERT_RAM_CRITICAL_PERCENT=95
AFROGATE_ALERT_DISK_WARNING_FREE_PERCENT=15
AFROGATE_ALERT_DISK_CRITICAL_FREE_PERCENT=10
AFROGATE_ALERT_PING_WARNING_MS=100
AFROGATE_ALERT_PING_CRITICAL_MS=150
AFROGATE_ALERT_JITTER_WARNING_MS=40
AFROGATE_ALERT_JITTER_CRITICAL_MS=80
AFROGATE_ALERT_PACKET_LOSS_WARNING_PERCENT=1
AFROGATE_ALERT_PACKET_LOSS_CRITICAL_PERCENT=5

# Dashboard
VITE_API_BASE_URL=http://127.0.0.1:7000/api

# Agent
AFROGATE_AGENT_ID=local-dev-agent
AFROGATE_API_URL=http://127.0.0.1:7000/api
AFROGATE_PUSH_INTERVAL_SECONDS=10
AFROGATE_AGENT_STATE_FILE=
# Optional synthetic ping probes. Leave empty unless you control/accept the targets.
AFROGATE_PING_TARGETS=
AFROGATE_PING_COUNT=3
AFROGATE_PING_TIMEOUT_SECONDS=2
# Optional protocol-aware route probes. Use synthetic targets you control.
# TCP targets are host:port. UDP/QUIC targets must reply to the small probe payload.
# DNS targets are hostnames to resolve through the local route.
# WireGuard route-probe rows are derived from local `wg` telemetry when available.
AFROGATE_TCP_PROBE_TARGETS=
AFROGATE_UDP_PROBE_TARGETS=
AFROGATE_QUIC_PROBE_TARGETS=
AFROGATE_DNS_PROBE_TARGETS=
AFROGATE_ROUTE_PROBE_COUNT=2
AFROGATE_ROUTE_PROBE_TIMEOUT_SECONDS=2
# Optional route-probe dimensions for operator/outbound/time-window analytics.
AFROGATE_ROUTE_PROBE_ROUTE_GROUP=main
AFROGATE_ROUTE_PROBE_OUTBOUND_ID=
AFROGATE_ROUTE_PROBE_OUTBOUND_KEY=
AFROGATE_ROUTE_PROBE_OUTBOUND_NAME=
AFROGATE_ROUTE_PROBE_OPERATOR=
AFROGATE_ROUTE_PROBE_SCORE_PROFILE=
