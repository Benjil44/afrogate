# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://afrogate:afrogate@localhost:5432/afrogate
# Required before accepting agent metrics. Change this in every environment.
AFROGATE_AGENT_TOKEN=change-me-local-token
ADMIN_SESSION_SECRET=change-me-long-random-secret

# Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Agent
AFROGATE_AGENT_ID=local-dev-agent
AFROGATE_API_URL=http://localhost:4000/api
AFROGATE_PUSH_INTERVAL_SECONDS=10
